{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "provider": {
    "openai": {
      "options": {
        "apiKey": "{file:~/openaikey}"
      }
    },
    "anthropic": {
      "options": {
        "apiKey": "{file:~/anthropickey}"
      }
    },
    "openrouter": {
      "options": {
        "apiKey": "{file:~/openrouterkey}"
      },
      "models": {
        "z-ai/glm-5": {
          "reasoning": true,
          "options": {
            "provider": {
              "only": ["z-ai", "novita", "venice"],
              "sort": "throughput",
              "preferred_max_latency": 2,
              "preferred_min_throughput": {
                "p90": 40
              }
            }
          }
        },
        "z-ai/glm-4.7": {
          "reasoning": true,
          "options": {
            "provider": {
              "only": ["google-vertex", "novita"],
              "sort": "latency",
              "preferred_max_latency": 5,
              "preferred_min_throughput": {
                "p90": 50
              }
            }
          }
        },
        "moonshotai/kimi-k2.5": {
          "reasoning": true,
          "options": {
            "provider": {
              "sort": "latency",
              "only": [
                "novita",
                "moonshot"
              ],
              "preferred_max_latency": 5,
              "preferred_min_throughput": {
                "p90": 50
              },
            }
          }
        },
        "deepseek/deepseek-v3.1-terminus:exacto": {
          "reasoning": true,
          "options": {
            "provider": {
              "only": ["novita", "atlas-cloud"],
              "sort": "latency",
              "preferred_max_latency": 5,
              "preferred_min_throughput": {
                "p90": 50
              }
            }
          }
        },
        "deepseek/deepseek-v3.2-exp": {
          "reasoning": true,
          "options": {
            "provider": {
              "only": ["deepseek", "novita", "atlas-cloud"],
              "sort": "latency"
            }
          }
        }
      }
    },
  },
  // "mcp": {
  //   "playwright": {
  //     "type": "local",
  //     "command": [
  //       "npx",
  //       "@playwright/mcp@latest"
  //     ],
  //     "enabled": true
  //   }
  // },
}

